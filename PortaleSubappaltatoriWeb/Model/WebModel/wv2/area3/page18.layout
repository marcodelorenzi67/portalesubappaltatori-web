<wr-page>
  <wr-content for="page-content">
    <wd-grid>
      <wd-row>
        <wd-cell [width]="12">
          <wd-card title="main">
            <wr-content for="content">
              <wd-grid>
                <wd-row>
                  <wd-cell [width]="12">
                    <wd-card elevation="0" actions="main/frm13/oslte30 | main/frm13/clear">
                      <wr-content for="content">
                        <wd-grid>
                          <wd-row>
                            <wd-cell [width]="4">
                              <wd-input appearance="outline" context="main/frm13/fld28"></wd-input>
                            </wd-cell>
                            <wd-cell [width]="4">
                              <wd-input appearance="outline" context="main/frm13/fld29"></wd-input>
                            </wd-cell>
                            <wd-cell [width]="4">
                              <wd-select appearance="outline" context="main/frm13/sfld8"></wd-select>
                            </wd-cell>
                          </wd-row>
                        </wd-grid>
                      </wr-content>
                      <wr-content for="action[oslte30]">
                        <wd-button color="primary" iconText="search"></wd-button>
                      </wr-content>
                      <wr-content for="action[clear]">
                        <wd-button></wd-button>
                      </wr-content>
                    </wd-card>
                  </wd-cell>
                </wd-row>
                <wd-row>
                  <wd-cell [width]="12">
                    <wd-data-grid *ngIf="valueOf('/parameters/prd8') === 2" elevation="0" cols="main/lst8/data/_be_att7 | main/lst8/data/_be_att8 | main/lst8/data/_be_att66 | main/lst8/data/_be_att178o | main/lst8/data/_be_att180o | main/lst8/data/_be_att187o" [rows]="valueOf('main/lst8/data')" events="main/lst8/data/oslte34p | main/lst8/data/oslte45p" paginator="main/lst8/paging" colsOrder="_be_att7 _be_att8 _be_att66 _be_att187o _be_att178o _be_att180o">
                      <wr-content for="header[_be_att7]">
                        {{ labelOf('.') | wrLocalize }}
                      </wr-content>
                      <wr-content for="data[_be_att7]">
                        {{ valueOf('.', row) }}
                      </wr-content>
                      <wr-content for="header[_be_att8]">
                        {{ labelOf('.') | wrLocalize }}
                      </wr-content>
                      <wr-content for="data[_be_att8]">
                        {{ valueOf('.', row) }}
                      </wr-content>
                      <wr-content for="header[_be_att66]">
                        {{ labelOf('.') | wrLocalize }}
                      </wr-content>
                      <wr-content for="data[_be_att66]">
                        {{ valueOf('.', row) }}
                      </wr-content>
                      <wr-content for="header-actions">
                        <wd-button context="main/gctu10p/oslte31p" iconText="add"></wd-button>
                        <wd-button context="main/gctu10p/oslte210p" iconText="playlist_add" [visible]="valueOf('accessible') &amp;&amp; valueOf('/parameters/prd19p')"></wd-button>
                      </wr-content>
                      <wr-content for="event[oslte34p]">
                        <wd-button variant="mat-icon-button" color="primary" iconText="edit" [visible]="valueOf('accessible') &amp;&amp; valueOf('/main/lst8/data/_be_att181o', row) === valueOf('/parameters/prd8')"></wd-button>
                      </wr-content>
                      <wr-content for="event[oslte45p]">
                        <wd-button variant="mat-icon-button" color="primary" iconText="info_outline" [visible]="valueOf('accessible') &amp;&amp; valueOf('/main/lst8/data/statoregistrazioneCodice', row) != 'B'"></wd-button>
                      </wr-content>
                      <wr-content for="header[_be_att178o]">
                        {{ labelOf('.') | wrLocalize }}
                      </wr-content>
                      <wr-content for="data[_be_att178o]">
                        <wd-icon iconText="lens" *ngIf="valueOf('.', row)" style="color: #f05050;"></wd-icon>
                        <wd-icon iconText="lens" *ngIf="!valueOf('.', row)" style="color: #27c24c;"></wd-icon>
                      </wr-content>
                      <wr-content for="header[_be_att180o]">
                        {{ labelOf('.') | wrLocalize }}
                      </wr-content>
                      <wr-content for="data[_be_att180o]">
                        <wd-icon iconText="lens" *ngIf="valueOf('.', row)" style="color: #f05050;"></wd-icon>
                        <wd-icon iconText="lens" *ngIf="!valueOf('.', row)" style="color: #27c24c;"></wd-icon>
                      </wr-content>
                      <wr-content for="header[_be_att187o]">
                        {{ labelOf('.') | wrLocalize }}
                      </wr-content>
                      <wr-content for="data[_be_att187o]">
                        <wd-icon iconText="lens" *ngIf="valueOf('.', row)" style="color: #f05050;"></wd-icon>
                        <wd-icon iconText="lens" *ngIf="!valueOf('.', row)" style="color: #27c24c;"></wd-icon>
                      </wr-content>
                    </wd-data-grid>
                    <wd-data-grid *ngIf="valueOf('/parameters/prd8') === 1" elevation="0" cols="main/lst8/data/_be_att7 | main/lst8/data/_be_att8 | main/lst8/data/_be_att66 | main/lst8/data/_be_att177o | main/lst8/data/_be_att179o | main/lst8/data/_be_att186o" [rows]="valueOf('main/lst8/data')" events="main/lst8/data/oslte34p | main/lst8/data/oslte45p" paginator="main/lst8/paging" colsOrder="_be_att7 _be_att8 _be_att66 _be_att186o _be_att177o _be_att179o">
                      <wr-content for="header[_be_att7]">
                        {{ labelOf('.') | wrLocalize }}
                      </wr-content>
                      <wr-content for="data[_be_att7]">
                        {{ valueOf('.', row) }}
                      </wr-content>
                      <wr-content for="header[_be_att8]">
                        {{ labelOf('.') | wrLocalize }}
                      </wr-content>
                      <wr-content for="data[_be_att8]">
                        {{ valueOf('.', row) }}
                      </wr-content>
                      <wr-content for="header[_be_att66]">
                        {{ labelOf('.') | wrLocalize }}
                      </wr-content>
                      <wr-content for="data[_be_att66]">
                        {{ valueOf('.', row) }}
                      </wr-content>
                      <wr-content for="header-actions">
                        <wd-button context="main/gctu10p/oslte31p" iconText="add"></wd-button>
                        <wd-button context="main/gctu10p/oslte210p" iconText="playlist_add" [visible]="valueOf('accessible') &amp;&amp; valueOf('/parameters/prd19p')"></wd-button>
                      </wr-content>
                      <wr-content for="event[oslte34p]">
                        <wd-button variant="mat-icon-button" color="primary" iconText="edit" [visible]="valueOf('accessible') &amp;&amp; valueOf('/main/lst8/data/_be_att181o', row) === valueOf('/parameters/prd8')"></wd-button>
                      </wr-content>
                      <wr-content for="event[oslte45p]">
                        <wd-button variant="mat-icon-button" color="primary" iconText="info_outline" [visible]="valueOf('accessible') &amp;&amp; valueOf('/main/lst8/data/statoregistrazioneCodice', row) != 'B'"></wd-button>
                      </wr-content>
                      <wr-content for="header[_be_att177o]">
                        {{ labelOf('.') | wrLocalize }}
                      </wr-content>
                      <wr-content for="data[_be_att177o]">
                        <wd-icon iconText="lens" *ngIf="valueOf('.', row)" style="color: #f05050;"></wd-icon>
                        <wd-icon iconText="lens" *ngIf="!valueOf('.', row)" style="color: #27c24c;"></wd-icon>
                      </wr-content>
                      <wr-content for="header[_be_att179o]">
                        {{ labelOf('.') | wrLocalize }}
                      </wr-content>
                      <wr-content for="data[_be_att179o]">
                        <wd-icon iconText="lens" *ngIf="valueOf('.', row)" style="color: #f05050;"></wd-icon>
                        <wd-icon iconText="lens" *ngIf="!valueOf('.', row)" style="color: #27c24c;"></wd-icon>
                      </wr-content>
                      <wr-content for="header[_be_att186o]">
                        {{ labelOf('.') | wrLocalize }}
                      </wr-content>
                      <wr-content for="data[_be_att186o]">
                        <wd-icon iconText="lens" *ngIf="valueOf('.', row)" style="color: #f05050;"></wd-icon>
                        <wd-icon iconText="lens" *ngIf="!valueOf('.', row)" style="color: #27c24c;"></wd-icon>
                      </wr-content>
                    </wd-data-grid>
                  </wd-cell>
                </wd-row>
              </wd-grid>
            </wr-content>
            <wr-content for="title[main]">
              {{ labelOf('.') | wrLocalize }}
            </wr-content>
          </wd-card>
        </wd-cell>
      </wd-row>
    </wd-grid>
  </wr-content>
  <wr-content for="breadcrumb">
    <wd-alert [messages]="valueOf('main/msg16p/messages')" [localized]="true" color="success"></wd-alert>
  </wr-content>
</wr-page>