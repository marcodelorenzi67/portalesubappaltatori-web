<wr-page>
  <wr-content for="page-content">
    <wd-button context="backEvent" iconText="arrow_back"></wd-button>
    <wd-card title="main" actions="main/frm14p/oslte32p | main/frm14p/oslte33p">
      <wr-content for="content">
        <wd-grid>
          <wd-row>
            <wd-cell [width]="12">
              <wd-card elevation="0" title="main/frm14p">
                <wr-content for="content">
                  <wd-grid>
                    <wd-row>
                      <wd-cell [width]="4">
                        <wd-input appearance="outline" context="main/frm14p/fld34p"></wd-input>
                      </wd-cell>
                      <wd-cell [width]="4">
                        <wd-input appearance="outline" context="main/frm14p/fld35p"></wd-input>
                      </wd-cell>
                      <wd-cell [width]="4">
                        <wd-select appearance="outline" context="main/frm14p/sfld9p"></wd-select>
                      </wd-cell>
                    </wd-row>
                  </wd-grid>
                </wr-content>
                <wr-content for="title[frm14p]">
                  {{ 'Dati Fornitore' | wrLocalize }}
                </wr-content>
              </wd-card>
            </wd-cell>
          </wd-row>
          <wd-row>
            <wd-cell [width]="12">
              <wd-card elevation="0" title="main/frm14p">
                <wr-content for="content">
                  <wd-grid>
                    <wd-row>
                      <wd-cell [width]="3">
                        <wd-input appearance="outline" context="main/frm14p/fld33p"></wd-input>
                      </wd-cell>
                      <wd-cell [width]="3">
                        <wd-input context="main/frm14p/fld36p" appearance="outline"></wd-input>
                      </wd-cell>
                      <wd-cell [width]="3">
                        <wd-input appearance="outline" context="main/frm14p/fld66p"></wd-input>
                      </wd-cell>
                      <wd-cell [width]="3">
                        <wd-input appearance="outline" context="main/frm14p/fld37p"></wd-input>
                      </wd-cell>
                    </wd-row>
                  </wd-grid>
                </wr-content>
                <wr-content for="title[frm14p]">
                  {{ labelOf('.') | wrLocalize }}
                </wr-content>
              </wd-card>
            </wd-cell>
          </wd-row>
        </wd-grid>
      </wr-content>
      <wr-content for="title[main]">
        {{ labelOf('.') | wrLocalize }}
      </wr-content>
      <wr-content for="action[oslte32p]">
        <wd-button color="primary" iconText="save"></wd-button>
      </wr-content>
      <wr-content for="action[oslte33p]">
        <wd-button color="success" iconText="send"></wd-button>
      </wr-content>
    </wd-card>
  </wr-content>
</wr-page>