<wr-page>
  <wr-content for="page-content">
    <wd-card title="main">
      <wr-content for="content">
        <wd-grid>
          <wd-row>
            <wd-cell [width]="12">
              <wd-card elevation="0" actions="main/frm38p/oslte206p | main/frm38p/oslte207p">
                <wr-content for="content">
                  <wd-grid>
                    <wd-row>
                      <wd-cell [width]="3">
                        <wd-select appearance="outline" context="main/frm38p/sfld30p"></wd-select>
                      </wd-cell>
                      <wd-cell [width]="3">
                        <wd-select context="main/frm38p/sfld31p" appearance="outline"></wd-select>
                      </wd-cell>
                      <wd-cell [width]="3">
                        <wd-select appearance="outline" context="main/frm38p/sfld29p"></wd-select>
                      </wd-cell>
                      <wd-cell [width]="3">
                        <wd-select appearance="outline" context="main/frm38p/sfld32p"></wd-select>
                      </wd-cell>
                    </wd-row>
                    <wd-row>
                      <wd-cell [width]="3">
                        <wd-datepicker appearance="outline" context="main/frm38p/fld130p"></wd-datepicker>
                      </wd-cell>
                      <wd-cell [width]="3">
                        <wd-datepicker context="main/frm38p/fld131p" appearance="outline"></wd-datepicker>
                      </wd-cell>
                      <wd-cell [width]="3">
                        <wd-toggle context="main/frm38p/fld132p"></wd-toggle>
                      </wd-cell>
                      <wd-cell [width]="3"></wd-cell>
                    </wd-row>
                  </wd-grid>
                </wr-content>
                <wr-content for="action[oslte206p]">
                  <wd-button color="primary" iconText="search"></wd-button>
                </wr-content>
                <wr-content for="action[oslte207p]">
                  <wd-button></wd-button>
                </wr-content>
              </wd-card>
            </wd-cell>
          </wd-row>
          <wd-row>
            <wd-cell [width]="12">
              <wd-data-grid elevation="0" cols="main/lst45p/data/_be_att23 | main/lst45p/data/_be_att24 | main/lst45p/data/_be_att97o | main/lst45p/data/_be_att88o | main/lst45p/data/_be_att89o | main/lst45p/data/_be_att99o | main/lst45p/data/_be_att87o | main/lst45p/data/_be_att35" [rows]="valueOf('main/lst45p/data')" events="main/lst45p/data/oslte204p | main/lst45p/data/oslte205p" eventsOrder="oslte203p oslte204p oslte205p" colsOrder="_be_att23 _be_att24 _be_att97o _be_att88o _be_att89o _be_att99o _be_att35 _be_att87o" paginator="main/lst45p/paging">
                <wr-content for="header[_be_att23]">
                  {{ labelOf('.') | wrLocalize }}
                </wr-content>
                <wr-content for="data[_be_att23]">
                  <wd-anchor type="file"></wd-anchor>
                </wr-content>
                <wr-content for="header[_be_att24]">
                  {{ labelOf('.') | wrLocalize }}
                </wr-content>
                <wr-content for="data[_be_att24]">
                  {{ valueOf('.', row) }}
                </wr-content>
                <wr-content for="header[_be_att97o]">
                  {{ labelOf('.') | wrLocalize }}
                </wr-content>
                <wr-content for="data[_be_att97o]">
                  {{ valueOf('.', row) }}
                </wr-content>
                <wr-content for="header[_be_att88o]">
                  {{ labelOf('.') | wrLocalize }}
                </wr-content>
                <wr-content for="data[_be_att88o]">
                  {{ valueOf('.', row) }}
                </wr-content>
                <wr-content for="header[_be_att89o]">
                  {{ labelOf('.') | wrLocalize }}
                </wr-content>
                <wr-content for="data[_be_att89o]">
                  {{ valueOf('.', row) }}
                </wr-content>
                <wr-content for="header[_be_att99o]">
                  {{ labelOf('.') | wrLocalize }}
                </wr-content>
                <wr-content for="data[_be_att99o]">
                  <span *ngIf="valueOf('/main/lst45p/data/statoallegatoCodice', row) === 'S'" class="allegato-scaduto">
                  {{ valueOf('.', row) | date:'wr-date' }}
                  </span>
                  <span *ngIf="valueOf('/main/lst45p/data/statoallegatoCodice', row) === 'IS'" class="allegato-inScadenza">
                  {{ valueOf('.', row) | date:'wr-date' }}
                  </span>
                  <span *ngIf="valueOf('/main/lst45p/data/statoallegatoCodice', row) != 'IS' && valueOf('/main/lst45p/data/statoallegatoCodice', row) != 'S'">
                  {{ valueOf('.', row) | date:'wr-date' }}
                  </span>
                </wr-content>
                <wr-content for="header[_be_att87o]">
                  {{ labelOf('.') | wrLocalize }}
                </wr-content>
                <wr-content for="data[_be_att87o]">
                  {{ valueOf('.', row) }}
                </wr-content>
                <wr-content for="event[oslte204p]">
                  <wd-button variant="mat-icon-button" color="primary" iconText="forward"></wd-button>
                </wr-content>
                <wr-content for="event[oslte205p]">
                  <wd-button variant="mat-icon-button" color="primary" iconText="error_outline"></wd-button>
                </wr-content>
                <wr-content for="header[_be_att35]">
                  {{ labelOf('.') | wrLocalize }}
                </wr-content>
                <wr-content for="data[_be_att35]">
                  {{ valueOf('.', row) == true ? 'S&igrave;' : 'No' }}
                </wr-content>
              </wd-data-grid>
            </wd-cell>
          </wd-row>
        </wd-grid>
      </wr-content>
      <wr-content for="title[main]">
        {{ labelOf('.') | wrLocalize }}
      </wr-content>
    </wd-card>
  </wr-content>
</wr-page>
<wd-dialog context="main/dpg26p" title=".">
  <wr-content for="content">
    <wd-data-grid cols="lst46p/data/_be_pdp202o | lst46p/data/_be_pdp201o | lst46p/data/_be_pdp198o" [rows]="valueOf('lst46p/data')" elevation="0" paginator="lst46p/paging">
      <wr-content for="header[_be_pdp202o]">
        {{ labelOf('.') | wrLocalize }}
      </wr-content>
      <wr-content for="data[_be_pdp202o]">
        {{ valueOf('.', row) }}
      </wr-content>
      <wr-content for="header[_be_pdp201o]">
        {{ labelOf('.') | wrLocalize }}
      </wr-content>
      <wr-content for="data[_be_pdp201o]">
        {{ valueOf('.', row) | date:'wr-timestamp' }}
      </wr-content>
      <wr-content for="header[_be_pdp198o]">
        {{ labelOf('.') | wrLocalize }}
      </wr-content>
      <wr-content for="data[_be_pdp198o]">
        {{ valueOf('.', row) }}
      </wr-content>
    </wd-data-grid>
  </wr-content>
  <wr-content for="title[dpg26p]">
    {{ labelOf('.') | wrLocalize }}
  </wr-content>
</wd-dialog>