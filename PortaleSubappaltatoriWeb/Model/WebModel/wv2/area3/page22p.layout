                          <wr-content for="header-actions">
                            <wd-button context="main/gctu14p/oslte56p" color="success" iconText="add"></wd-button>
                          </wr-content>
                          <wr-content for="event[oslte59p]">
                            <wd-button variant="mat-icon-button" color="primary" iconText="remove" [visible]="valueOf('accessible') &amp;&amp; valueOf('/main/lst12p/data/statoallegatoCodice', row) === 'B' &amp;&amp; !valueOf('/main/lst12p/data/_be_att90o', row)"></wd-button>
                          </wr-content>
                          <wr-content for="event[oslte60p]">
                            <wd-button variant="mat-icon-button" color="primary" [disabled]="valueOf('/main/dtl6p/data/statoregistrazioneCodice') != 'R'" iconText="send" [visible]="valueOf('accessible') &amp;&amp; valueOf('/main/lst12p/data/statoallegatoCodice', row) === 'B'" [confirm]="true"></wd-button>
                          </wr-content>
                          <wr-content for="event[oslte62p]">
                            <wd-button variant="mat-icon-button" color="success" iconText="check" [visible]="valueOf('accessible') &amp;&amp; valueOf('/main/lst12p/data/statoallegatoCodice', row) === 'V'" [confirm]="true"></wd-button>
                          </wr-content>
                          <wr-content for="event[oslte63p]">
                            <wd-button variant="mat-icon-button" color="accent" iconText="clear" [visible]="valueOf('accessible') &amp;&amp; valueOf('/main/lst12p/data/statoallegatoCodice', row) === 'V'" [confirm]="true"></wd-button>
