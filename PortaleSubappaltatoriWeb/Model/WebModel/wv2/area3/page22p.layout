                <mat-tab [label]="'Documentazione per il supappalto' | wrLocalize">
                  <wd-grid>
                    <wd-row>
                      <wd-cell [width]="12">
                        <wd-data-grid elevation="0" cols="main/lst12p/data/_be_att23 | main/lst12p/data/_be_att24 | main/lst12p/data/_be_att88o | main/lst12p/data/_be_att89o | main/lst12p/data/_be_att87o" [rows]="valueOf('main/lst12p/data')" events="main/lst12p/data/oslte59p | main/lst12p/data/oslte60p | main/lst12p/data/oslte62p | main/lst12p/data/oslte63p" title="main/lst12p" paginator="main/lst12p/paging" [useExcelLikeFilter]="true">
                          <wr-content for="header[_be_att23]">
