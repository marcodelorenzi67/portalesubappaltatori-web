<wr-page>
  <wr-content for="brand">
    <wd-image staticImage="assets/PortaleSubappaltatoriStyle/logo-galli-italo.png"></wd-image>
  </wr-content>
  <wr-content for="menu">
    <wd-menu menu="landmarks/area1 | landmarks/area4p | landmarks/area3/page24p | landmarks/area3/page18 | landmarks/area3/page25p" menuOrder="page24p page18 page25p area4p area1">
      <wr-content for="menu-item[area1]">
        <wd-menu-item menuItem="." [hasSubMenu]="true" color="primary" submenu="page4 | area2/page11 | area2/page12">
          <wr-content for="menu-item[page4]">
            <wd-menu-item></wd-menu-item>
          </wr-content>
          <wr-content for="menu-item[page11]">
            <wd-menu-item></wd-menu-item>
          </wr-content>
          <wr-content for="menu-item[page12]">
            <wd-menu-item></wd-menu-item>
          </wr-content>
        </wd-menu-item>
      </wr-content>
      <wr-content for="menu-item[area4p]">
        <wd-menu-item color="primary"></wd-menu-item>
      </wr-content>
      <wr-content for="menu-item[page24p]">
        <wd-menu-item color="primary"></wd-menu-item>
      </wr-content>
      <wr-content for="menu-item[page18]">
        <wd-menu-item color="primary"></wd-menu-item>
      </wr-content>
      <wr-content for="menu-item[page25p]">
        <wd-menu-item color="primary"></wd-menu-item>
      </wr-content>
    </wd-menu>
  </wr-content>
  <wr-content for="page-content"></wr-content>
</wr-page>