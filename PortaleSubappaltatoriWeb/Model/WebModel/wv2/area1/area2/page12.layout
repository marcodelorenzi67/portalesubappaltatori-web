<wr-page>
  <wr-content for="page-content">
    <wd-card title="main">
      <wr-content for="content">
        <wd-data-grid elevation="0" cols="main/lst4/data/_be_att46" [rows]="valueOf('main/lst4/data')" events="main/lst4/data/oslte18">
          <wr-content for="header[_be_att46]">
            {{ labelOf('.') | wrLocalize }}
          </wr-content>
          <wr-content for="data[_be_att46]">
            {{ valueOf('.', row) }}
          </wr-content>
          <wr-content for="event[oslte18]">
            <wd-button variant="mat-icon-button" color="primary" iconText="dvr"></wd-button>
          </wr-content>
        </wd-data-grid>
      </wr-content>
      <wr-content for="title[main]">
        {{ labelOf('.') | wrLocalize }}
      </wr-content>
    </wd-card>
  </wr-content>
</wr-page>