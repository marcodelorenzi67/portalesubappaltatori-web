<wr-page>
  <wr-content for="page-content">
    <wd-card elevation="8" title="main">
      <wr-content for="content">
        <wd-grid>
          <wd-row>
            <wd-cell [width]="6">
              <wd-data-grid elevation="0" cols="main/lst6/data/_be_att64 | main/lst6/data/_be_att65" checkField="main/lst6/data/_checked" [rows]="valueOf('main/lst6/data')" paginator="main/lst6/paging" events="main/lst6/data/oslte21" title="main/lst6">
                <wr-content for="header[_be_att64]">
                  {{ labelOf('.') | wrLocalize }}
                </wr-content>
                <wr-content for="data[_be_att64]">
                  {{ valueOf('.', row) }}
                </wr-content>
                <wr-content for="header[_be_att65]">
                  {{ labelOf('.') | wrLocalize }}
                </wr-content>
                <wr-content for="data[_be_att65]">
                  {{ valueOf('.', row) }}
                </wr-content>
                <wr-content for="event[oslte21]">
                  <wd-button variant="mat-icon-button" color="primary" iconText="remove"></wd-button>
                </wr-content>
                <wr-content for="header-actions">
                  <wd-button context="main/gctu9/oslte22" color="accent" iconText="remove"></wd-button>
                </wr-content>
                <wr-content for="title[lst6]">
                  {{ labelOf('.') | wrLocalize }}
                </wr-content>
              </wd-data-grid>
            </wd-cell>
            <wd-cell [width]="6">
              <wd-data-grid cols="main/lst7/data/_be_att64 | main/lst7/data/_be_att65" checkField="main/lst7/data/_checked" [rows]="valueOf('main/lst7/data')" title="main/lst7" events="main/lst7/data/oslte20" paginator="main/lst7/paging" elevation="0">
                <wr-content for="header[_be_att64]">
                  {{ labelOf('.') | wrLocalize }}
                </wr-content>
                <wr-content for="data[_be_att64]">
                  {{ valueOf('.', row) }}
                </wr-content>
                <wr-content for="header[_be_att65]">
                  {{ labelOf('.') | wrLocalize }}
                </wr-content>
                <wr-content for="data[_be_att65]">
                  {{ valueOf('.', row) }}
                </wr-content>
                <wr-content for="title[lst7]">
                  {{ labelOf('.') | wrLocalize }}
                </wr-content>
                <wr-content for="event[oslte20]">
                  <wd-button variant="mat-icon-button" color="primary" iconText="add"></wd-button>
                </wr-content>
                <wr-content for="header-actions">
                  <wd-button context="main/gctu9/oslte23" iconText="add" color="success"></wd-button>
                </wr-content>
              </wd-data-grid>
            </wd-cell>
          </wd-row>
        </wd-grid>
        <wd-container></wd-container>
      </wr-content>
      <wr-content for="title[main]">
        {{ labelOf('.') | wrLocalize }}
      </wr-content>
    </wd-card>
  </wr-content>
  <wr-content for="breadcrumb">
    <wd-button context="backEvent" iconText="arrow_back"></wd-button>
  </wr-content>
</wr-page>