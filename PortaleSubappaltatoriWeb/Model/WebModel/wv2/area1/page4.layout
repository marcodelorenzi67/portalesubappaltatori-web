<wr-page>
  <wr-content for="page-content">
    <wd-grid>
      <wd-row>
        <wd-cell [width]="12">
          <wd-card title="main">
            <wr-content for="content">
              <wd-grid>
                <wd-row>
                  <wd-cell [width]="12">
                    <wd-data-grid cols="main/lst2/data/_be_att18 | main/lst2/data/_be_att19 | main/lst2/data/_be_att20 | main/lst2/data/_be_att62" [rows]="valueOf('main/lst2/data')" title="main/lst2" paginator="main/lst2/paging" elevation="0">
                      <wr-content for="header[_be_att18]">
                        {{ labelOf('.') | wrLocalize }}
                      </wr-content>
                      <wr-content for="data[_be_att18]">
                        {{ valueOf('.', row) }}
                      </wr-content>
                      <wr-content for="header[_be_att19]">
                        {{ labelOf('.') | wrLocalize }}
                      </wr-content>
                      <wr-content for="data[_be_att19]">
                        {{ valueOf('.', row) }}
                      </wr-content>
                      <wr-content for="header[_be_att20]">
                        {{ labelOf('.') | wrLocalize }}
                      </wr-content>
                      <wr-content for="data[_be_att20]">
                        {{ valueOf('.', row) }}
                      </wr-content>
                      <wr-content for="title[lst2]">
                        {{ labelOf('.') | wrLocalize }}
                      </wr-content>
                      <wr-content for="header-actions">
                        <wd-button context="main/gctu2/oslte4" iconText="add" color="primary"></wd-button>
                      </wr-content>
                      <wr-content for="header[_be_att62]">
                        {{ labelOf('.') | wrLocalize }}
                      </wr-content>
                      <wr-content for="data[_be_att62]">
                        {{ valueOf('.', row) }}
                      </wr-content>
                    </wd-data-grid>
                  </wd-cell>
                </wd-row>
                <wd-row>
                  <wd-cell [width]="12">
                    <wd-data-grid cols="main/lst1/data/_be_att3 | main/lst1/data/_be_att4 | main/lst1/data/_be_att5 | main/lst1/data/_be_att94o" [rows]="valueOf('main/lst1/data')" title="main/lst1" paginator="main/lst1/paging" [useExcelLikeFilter]="true" elevation="0" events="main/lst1/data/oslte228p">
                      <wr-content for="title[lst1]">
                        {{ labelOf('.') | wrLocalize }}
                      </wr-content>
                      <wr-content for="header[_be_att3]">
                        {{ labelOf('.') | wrLocalize }}
                      </wr-content>
                      <wr-content for="data[_be_att3]">
                        {{ valueOf('.', row) }}
                      </wr-content>
                      <wr-content for="header[_be_att4]">
                        {{ labelOf('.') | wrLocalize }}
                      </wr-content>
                      <wr-content for="data[_be_att4]">
                        {{ valueOf('.', row) }}
                      </wr-content>
                      <wr-content for="header[_be_att5]">
                        {{ labelOf('.') | wrLocalize }}
                      </wr-content>
                      <wr-content for="data[_be_att5]">
                        {{ valueOf('.', row) }}
                      </wr-content>
                      <wr-content for="event[oslte228p]">
                        <wd-button variant="mat-icon-button" color="primary" iconText="create"></wd-button>
                      </wr-content>
                      <wr-content for="header[_be_att94o]">
                        {{ labelOf('.') | wrLocalize }}
                      </wr-content>
                      <wr-content for="data[_be_att94o]">
                        {{ valueOf('.', row) == true ? 'Sě' : 'No' }}
                      </wr-content>
                    </wd-data-grid>
                  </wd-cell>
                </wd-row>
              </wd-grid>
            </wr-content>
            <wr-content for="title[main]">
              {{ labelOf('.') | wrLocalize }}
            </wr-content>
          </wd-card>
        </wd-cell>
      </wd-row>
    </wd-grid>
  </wr-content>
</wr-page>