<wr-page>
  <wr-content for="page-content">
    <wd-card title="main">
      <wr-content for="content">
        <wd-grid>
          <wd-row>
            <wd-cell [width]="12">
              <wd-data-grid elevation="0" cols="main/lst10p/data/_be_att70o | main/lst10p/data/_be_att69o | main/lst10p/data/_be_att77o | main/lst10p/data/_be_att78o | main/lst10p/data/_be_att124o | main/lst10p/data/_be_att125o" [rows]="valueOf('main/lst10p/data')" paginator="main/lst10p/paging" [useExcelLikeFilter]="true" colsOrder="_be_att70o _be_att69o _be_att78o _be_att77o">
                <wr-content for="header[_be_att70o]">
                  {{ labelOf('.') | wrLocalize }}
                </wr-content>
                <wr-content for="data[_be_att70o]">
                  {{ valueOf('.', row) }}
                </wr-content>
                <wr-content for="header[_be_att69o]">
                  {{ labelOf('.') | wrLocalize }}
                </wr-content>
                <wr-content for="data[_be_att69o]">
                  {{ valueOf('.', row) | date:'wr-timestamp' }}
                </wr-content>
                <wr-content for="header[_be_att77o]">
                  {{ labelOf('.') | wrLocalize }}
                </wr-content>
                <wr-content for="data[_be_att77o]">
                  {{ valueOf('.', row) }}
                </wr-content>
                <wr-content for="header[_be_att78o]">
                  {{ labelOf('.') | wrLocalize }}
                </wr-content>
                <wr-content for="data[_be_att78o]">
                  {{ valueOf('.', row) }}
                </wr-content>
                <wr-content for="header[_be_att124o]">
                  {{ labelOf('.') | wrLocalize }}
                </wr-content>
                <wr-content for="data[_be_att124o]">
                  {{ valueOf('.', row) }}
                </wr-content>
                <wr-content for="header[_be_att125o]">
                  {{ labelOf('.') | wrLocalize }}
                </wr-content>
                <wr-content for="data[_be_att125o]">
                  {{ valueOf('.', row) }}
                </wr-content>
              </wd-data-grid>
            </wd-cell>
          </wd-row>
        </wd-grid>
      </wr-content>
      <wr-content for="title[main]">
        {{ labelOf('.') | wrLocalize }}
      </wr-content>
    </wd-card>
  </wr-content>
</wr-page>