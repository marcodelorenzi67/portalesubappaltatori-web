<wr-page>
  <wr-content for="enviroment">
    <div *ngIf="valueOf('main/msg8/messages') && valueOf('main/msg8/messages')[0] != 'prod'" class="alert-enviroment">{{ 'testEnv' | wrLocalize }}</div>
  </wr-content>
  <wr-content for="footer">
    <div class="footer-left">
      {{'Realizzato con ' | wrLocalize }}
      <a href="https://www.webratio.com" target="_blank">
        {{'WebRatio' | wrLocalize }}
      </a>
    </div>
    <div class="footer-right">
      {{'Versione' | wrLocalize }} {{ valueOf("app/version") }}
    </div>
  </wr-content>
  <wr-content for="logo">
    <wd-image id="login-logo" staticImage="assets/PortaleSubappaltatoriStyle/logo-galli-italo.png"></wd-image>
    
  </wr-content>
  <wr-content for="message">
    <wd-alert [localized]="true" [messages]="valueOf('main/msg6/messages')" color="success"></wd-alert>
    <wd-alert [localized]="true" [messages]="valueOf('main/msg7/messages')" color="warn"></wd-alert>
  </wr-content>
</wr-page>