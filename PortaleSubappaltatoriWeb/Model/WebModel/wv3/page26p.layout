<wr-page>
  <wr-content for="page-content">
    <wd-card title="main" actions="main/frm29p/oslte106p">
      <wr-content for="content">
        <wd-grid>
          <wd-row>
            <wd-cell [width]="12">
              <wd-card elevation="0">
                <wr-content for="content">
                  <wd-container elements="main/frm29p/fld89p | main/frm29p/fld88p" elementsOrder="fld88p fld89p">
                    <wr-content for="element[fld89p]">
                      <wd-textarea appearance="outline"></wd-textarea>
                    </wr-content>
                    <wr-content for="element[fld88p]">
                      <wd-input type="text" [showLabel]="true" appearance="outline"></wd-input>
                    </wr-content>
                  </wd-container>
                </wr-content>
              </wd-card>
            </wd-cell>
          </wd-row>
          <wd-row>
            <wd-cell [width]="12">
              <wd-data-grid elevation="0" cols="main/lst22p/data/_be_pdp190o" [rows]="valueOf('main/lst22p/data')" events="main/lst22p/data/oslte107p" paginator="main/lst22p/paging">
                <wr-content for="header[_be_pdp190o]">
                  {{ labelOf('.') | wrLocalize }}
                </wr-content>
                <wr-content for="data[_be_pdp190o]">
                  <wd-anchor type="file"></wd-anchor>
                </wr-content>
                <wr-content for="event[oslte107p]">
                  <wd-button variant="mat-icon-button" color="accent" iconText="clear" [confirm]="true"></wd-button>
                </wr-content>
                <wr-content for="header-actions">
                  <wd-button context="main/frm29p/oslte109p" iconText="add" variant="mat-icon-button"></wd-button>
                </wr-content>
              </wd-data-grid>
            </wd-cell>
          </wd-row>
        </wd-grid>
      </wr-content>
      <wr-content for="title[main]">
        {{ labelOf('.') | wrLocalize }}
      </wr-content>
      <wr-content for="action[oslte106p]">
        <wd-button color="success" [confirm]="true"></wd-button>
      </wr-content>
    </wd-card>
  </wr-content>
  <wr-content for="breadcrumb">
    <wd-button context="backEvent" iconText="arrow_back"></wd-button>
  </wr-content>
</wr-page>
<wd-dialog context="main/dpg14p" actions="frm30p/oslte108p">
  <wr-content for="content">
    <wd-card elevation="0">
      <wr-content for="content">
        <wd-container elements="frm30p/fld90p">
          <wr-content for="element[fld90p]">
            <wd-file-input></wd-file-input>
          </wr-content>
        </wd-container>
      </wr-content>
    </wd-card>
  </wr-content>
  <wr-content for="action[oslte108p]">
    <wd-button color="success"></wd-button>
  </wr-content>
</wd-dialog>