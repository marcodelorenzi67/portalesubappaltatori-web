<wr-page>
  <wr-content for="page-content">
    <wd-grid>
      <wd-row>
        <wd-cell [width]="6" [offset]="3">
          <wd-card actions="main/frm16p/oslte40p" title="main/frm16p">
            <wr-content for="content">
              <wd-grid>
                <wd-row>
                  <wd-cell [width]="6" [offset]="3">
                    <wd-select appearance="outline" context="main/frm16p/sfld12p"></wd-select>
                  </wd-cell>
                </wd-row>
              </wd-grid>
              <wd-container></wd-container>
            </wr-content>
            <wr-content for="title[frm16p]">
              {{ labelOf('.') | wrLocalize }}
            </wr-content>
            <wr-content for="action[oslte40p]">
              <wd-button color="success"></wd-button>
            </wr-content>
          </wd-card>
        </wd-cell>
      </wd-row>
    </wd-grid>
  </wr-content>
</wr-page>