</wr-page>
<wd-dialog context="main/dpg8p" actions="frm22p/oslte71p">
  <wr-content for="action[oslte71p]">
    <wd-button color="success" [confirm]="true"></wd-button>
  </wr-content>
  <wr-content for="content">
    <wd-card elevation="0">
      <wr-content for="content">
        <wd-container elements="frm22p/fld57p | frm22p/fld58p | frm22p/fld81p" elementsOrder="fld57p fld81p fld58p">
          <wr-content for="element[fld57p]">
            <wd-file-input></wd-file-input>
          </wr-content>
          <wr-content for="element[fld58p]">
            <wd-input type="text" [showLabel]="true" appearance="outline"></wd-input>
          </wr-content>
          <wr-content for="element[fld81p]">
            <wd-datepicker appearance="outline"></wd-datepicker>
          </wr-content>
        </wd-container>
      </wr-content>
    </wd-card>
  </wr-content>
</wd-dialog>
<wd-dialog context="main/dpg17p">
  <wr-content for="content">
    <wd-data-grid elevation="0" cols="lst25p/data/_be_att101o" [rows]="valueOf('lst25p/data')" paginator="lst25p/paging">
      <wr-content for="header[_be_att101o]">
        {{ labelOf('.') | wrLocalize }}
      </wr-content>
      <wr-content for="data[_be_att101o]">
        <wd-anchor type="file"></wd-anchor>
      </wr-content>
    </wd-data-grid>
  </wr-content>
</wd-dialog>
<wd-dialog context="main/dpg21p" [minWidth]="800">
  <wr-content for="content">
    <wd-card elevation="0" actions="frm33p/oslte137p">
      <wr-content for="content">
        <wd-grid>
          <wd-row>
            <wd-cell [width]="6">
              <wd-select appearance="outline" context="frm33p/sfld20p" filterPredicate="begins with"></wd-select>
            </wd-cell>
            <wd-cell [width]="6">
              <wd-select appearance="outline" context="frm33p/sfld21p"></wd-select>
            </wd-cell>
          </wd-row>
          <wd-row>
            <wd-cell [width]="4">
              <wd-input context="frm33p/fld96p" appearance="outline"></wd-input>
            </wd-cell>
            <wd-cell [width]="4">
              <wd-input context="frm33p/fld97p" appearance="outline"></wd-input>
            </wd-cell>
            <wd-cell [width]="4">
              <wd-input context="frm33p/fld95p" appearance="outline"></wd-input>
            </wd-cell>
          </wd-row>
        </wd-grid>
      </wr-content>
      <wr-content for="action[oslte137p]">
        <wd-button></wd-button>
      </wr-content>
    </wd-card>
  </wr-content>
</wd-dialog>