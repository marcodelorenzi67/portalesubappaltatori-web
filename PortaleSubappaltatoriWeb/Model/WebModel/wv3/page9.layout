<wd-dialog context="main/dpg8p">
  <wr-content for="content">
    <wd-card elevation="0" actions="frm22p/oslte71p">
      <wr-content for="content">
        <wd-container elements="frm22p/fld57p | frm22p/fld58p | frm22p/fld81p | frm22p/fld124p | frm22p/fld126p" elementsOrder="fld57p fld124p fld81p fld58p">
