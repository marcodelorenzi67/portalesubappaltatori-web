                          </wr-content>
                          <wr-content for="header[_be_att87o]">
                            {{ labelOf('.') | wrLocalize }}
                          </wr-content>
                          <wr-content for="data[_be_att87o]">
                            {{ valueOf('.', row) }}
                          </wr-content>
                          <wr-content for="title[lst14p]">
                            {{ labelOf('.') | wrLocalize }}
                          </wr-content>
                          <wr-content for="event[oslte70p]">
                            <wd-button variant="mat-icon-button" color="accent" iconText="description" [visible]="valueOf('accessible') &amp;&amp; valueOf('/main/lst14p/data/statoallegatoCodice', row) === 'I'"></wd-button>
                          </wr-content>
                        </wd-data-grid>
                      </wd-cell>
                    </wd-row><wd-row><wd-cell [width]="12">
                      <wd-data-grid elevation="0" cols="main/lst16p/data/_be_att23 | main/lst16p/data/_be_att24 | main/lst16p/data/_be_att88o | main/lst16p/data/_be_att89o | main/lst16p/data/_be_att87o | main/lst16p/data/_be_att25" [rows]="valueOf('main/lst16p/data')" title="main/lst16p" paginator="main/lst16p/paging" [useExcelLikeFilter]="true">
                        <wr-content for="header[_be_att23]">
                          {{ labelOf('.') | wrLocalize }}
                        </wr-content>
                        <wr-content for="data[_be_att23]">
                          <wd-anchor type="file"></wd-anchor>
                        </wr-content>
                        <wr-content for="header[_be_att24]">
                          {{ labelOf('.') | wrLocalize }}
                        </wr-content>
                        <wr-content for="data[_be_att24]">
                          {{ valueOf('.', row) }}
                        </wr-content>
                        <wr-content for="header[_be_att88o]">
                          {{ labelOf('.') | wrLocalize }}
                        </wr-content>
                        <wr-content for="data[_be_att88o]">
                          {{ valueOf('.', row) }}
                        </wr-content>
                        <wr-content for="header[_be_att89o]">
                          {{ labelOf('.') | wrLocalize }}
                        </wr-content>
                        <wr-content for="data[_be_att89o]">
                          {{ valueOf('.', row) }}
                        </wr-content>
                        <wr-content for="header[_be_att87o]">
                          {{ labelOf('.') | wrLocalize }}
                        </wr-content>
                        <wr-content for="data[_be_att87o]">
                          {{ valueOf('.', row) }}
                        </wr-content>
                        <wr-content for="header[_be_att25]">
                          {{ labelOf('.') | wrLocalize }}
                        </wr-content>
                        <wr-content for="data[_be_att25]">
                          {{ valueOf('.', row) }}
                        </wr-content>
                        <wr-content for="title[lst16p]">
                          {{ labelOf('.') | wrLocalize }}
                        </wr-content>
                      </wd-data-grid>
                    </wd-cell></wd-row>
                  </wd-grid>
                </mat-tab>
                <mat-tab [label]="'Documentazione aggiuntiva' | wrLocalize"></mat-tab>
                <mat-tab [label]="'Comunicazioni' | wrLocalize">
                  <wd-grid>
                    <wd-row>
                      <wd-cell [width]="12">
                        <wd-data-grid elevation="0" cols="main/lst9p/data/_be_att74o" [expandable]="true" [detailRow]="true" [rows]="valueOf('main/lst9p/data')">
                          <wr-content for="header[_be_att74o]">
                            {{ labelOf('.') | wrLocalize }}
                          </wr-content>
                          <wr-content for="data[_be_att74o]">
                            {{ valueOf('.', row) }}
                          </wr-content>
                          <wr-content for="header-actions">
                            <wd-button iconText="add" context="main/gctu13p/oslte41p" variant="mat-icon-button"></wd-button>
                          </wr-content>
                          <wr-content for="detail">
                            <wd-card elevation="0">
                              <wr-content for="content">
                                <wd-container elements="main/lst9p/data/_be_att75o">
                                  <wr-content for="element[_be_att75o]">
                                    <span>
                                      <span class="header">
                                        {{ labelOf('.') | wrLocalize }}
                                      </span>
                                      <span class="value">
                                        {{ valueOf('.', row) }}
                                      </span>
                                    </span>
                                  </wr-content>
                                </wd-container>
                              </wr-content>
                            </wd-card>
                          </wr-content>
                        </wd-data-grid>
                      </wd-cell>
                    </wd-row>
                  </wd-grid>
                </mat-tab>
              </mat-tab-group>
            </wd-cell>
          </wd-row>
        </wd-grid>
      </wr-content>
      <wr-content for="title[main]">
        {{ labelOf('.') | wrLocalize }}
      </wr-content>
    </wd-card>
  </wr-content>
</wr-page>
<wd-dialog context="main/dpg4p" title="." actions="frm17p/oslte42p">
  <wr-content for="title[dpg4p]">
    {{ labelOf('.') | wrLocalize }}
  </wr-content>
  <wr-content for="content">
    <wd-card elevation="0">
      <wr-content for="content">
        <wd-container elements="frm17p/fld39p | frm17p/fld40p">
          <wr-content for="element[fld39p]">
            <wd-input type="text" [showLabel]="true" appearance="outline"></wd-input>
          </wr-content>
          <wr-content for="element[fld40p]">
            <wd-textarea appearance="outline"></wd-textarea>
          </wr-content>
        </wd-container>
      </wr-content>
    </wd-card>
  </wr-content>
  <wr-content for="action[oslte42p]">
    <wd-button color="success" iconText="save"></wd-button>
  </wr-content>
</wd-dialog>
<wd-dialog context="main/dpg8p" actions="frm22p/oslte71p">
  <wr-content for="action[oslte71p]">
    <wd-button color="success" [confirm]="true"></wd-button>
  </wr-content>
  <wr-content for="content">
    <wd-card elevation="0">
      <wr-content for="content">
        <wd-container elements="frm22p/fld57p | frm22p/fld58p">
          <wr-content for="element[fld57p]">
            <wd-file-input></wd-file-input>
          </wr-content>
          <wr-content for="element[fld58p]">
            <wd-input type="text" [showLabel]="true" appearance="outline"></wd-input>
          </wr-content>
        </wd-container>
      </wr-content>
    </wd-card>
  </wr-content>
</wd-dialog>