                          </wr-content>
                          <wr-content for="event[oslte143p]">
                            <wd-button variant="mat-icon-button" color="primary" iconText="send" [visible]="valueOf('accessible') &amp;&amp; (valueOf('/main/lst30p/data/statoallegatoCodice', row) === 'B' || valueOf('/main/lst30p/data/statoallegatoCodice', row) === 'I')"></wd-button>
