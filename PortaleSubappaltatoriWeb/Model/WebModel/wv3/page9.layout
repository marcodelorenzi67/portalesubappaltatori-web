<wr-page>
  <wr-content for="page-content">
    <wd-card title="main">
      <wr-content for="content">
        <wd-grid>
          <wd-row>
            <wd-cell [width]="12">
              <mat-tab-group>
                <mat-tab [label]="'Anagrafica' | wrLocalize">
                  <wd-grid>
                    <wd-row>
                      <wd-cell [width]="12">
                        <wd-card elevation="0">
                          <wr-content for="content">
                            <wd-grid>
                              <wd-row>
                                <wd-cell [width]="3">
                                  <h2>
                                    Anagrafica Azienda
                                  </h2>
                                </wd-cell>
                              </wd-row>
                              <wd-row>
                                <wd-cell [width]="3">
                                  <span>
                                    <span class="header">
                                      {{ labelOf('main/dtl5p/data/_be_att7') | wrLocalize }}
                                    </span>
                                    <span class="value">
                                      {{ valueOf('main/dtl5p/data/_be_att7') }}
                                    </span>
                                  </span>
                                </wd-cell>
                                <wd-cell [width]="3">
                                  <span>
                                    <span class="header">
                                      {{ labelOf('main/dtl5p/data/_be_att8') | wrLocalize }}
                                    </span>
                                    <span class="value">
                                      {{ valueOf('main/dtl5p/data/_be_att8') }}
                                    </span>
                                  </span>
                                </wd-cell>
                                <wd-cell [width]="3">
                                  <span>
                                    <span class="header">
                                      {{ labelOf('main/dtl5p/data/_be_att72o') | wrLocalize }}
                                    </span>
                                    <span class="value">
                                      {{ valueOf('main/dtl5p/data/_be_att72o') }}
                                    </span>
                                  </span>
                                </wd-cell>
                                <wd-cell [width]="3">
                                  <span>
                                    <span class="header">
                                      {{ labelOf('main/dtl5p/data/_be_att66') | wrLocalize }}
                                    </span>
                                    <span class="value">
                                      {{ valueOf('main/dtl5p/data/_be_att66') }}
                                    </span>
                                  </span>
                                </wd-cell>
                              </wd-row>
                              <wd-row>
                                <wd-cell [width]="3">
                                  <h2>
                                    Anagrafica Referente
                                  </h2>
                                </wd-cell>
                              </wd-row>
                              <wd-row>
                                <wd-cell [width]="3">
                                  <span>
                                    <span class="header">
                                      {{ labelOf('main/dtl5p/data/_be_att9') | wrLocalize }}
                                    </span>
                                    <span class="value">
                                      {{ valueOf('main/dtl5p/data/_be_att9') }}
                                    </span>
                                  </span>
                                </wd-cell>
                                <wd-cell [width]="3">
                                  <span>
                                    <span class="header">
                                      {{ labelOf('main/dtl5p/data/_be_att10') | wrLocalize }}
                                    </span>
                                    <span class="value">
                                      {{ valueOf('main/dtl5p/data/_be_att10') }}
                                    </span>
                                  </span>
                                </wd-cell>
                                <wd-cell [width]="3">
                                  <span>
                                    <span class="header">
                                      {{ labelOf('main/dtl5p/data/_be_att12') | wrLocalize }}
                                    </span>
                                    <span class="value">
                                      {{ valueOf('main/dtl5p/data/_be_att12') }}
                                    </span>
                                  </span>
                                </wd-cell>
                              </wd-row>
                            </wd-grid>
                          </wr-content>
                        </wd-card>
                      </wd-cell>
                    </wd-row>
                  </wd-grid>
                </mat-tab>
                <mat-tab [label]="'Documentazione per il supappalto' | wrLocalize">
                  <wd-grid>
                    <wd-row>
                      <wd-cell [width]="12">
                        <wd-data-grid elevation="0" cols="main/lst14p/data/_be_att23 | main/lst14p/data/_be_att24 | main/lst14p/data/_be_att88o | main/lst14p/data/_be_att89o | main/lst14p/data/_be_att87o" [rows]="valueOf('main/lst14p/data')" title="main/lst14p" events="main/lst14p/data/oslte70p" [useExcelLikeFilter]="true" paginator="main/lst14p/paging">
                          <wr-content for="header[_be_att23]">
                            {{ labelOf('.') | wrLocalize }}
                          </wr-content>
                          <wr-content for="data[_be_att23]">
                            <wd-anchor type="file"></wd-anchor>
                          </wr-content>
                          <wr-content for="header[_be_att24]">
                            {{ labelOf('.') | wrLocalize }}
                          </wr-content>
                          <wr-content for="data[_be_att24]">
                            {{ valueOf('.', row) }}
                          </wr-content>
                          <wr-content for="header[_be_att88o]">
