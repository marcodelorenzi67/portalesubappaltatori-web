<wr-page>
  <wr-content for="page-content">
    <wd-card title="main" actions="main/frm34p/oslte146p">
      <wr-content for="content">
        <wd-grid>
          <wd-row>
            <wd-cell [width]="12">
              <wd-card elevation="0">
                <wr-content for="content">
                  <wd-grid>
                    <wd-row>
                      <wd-cell [width]="6">
                        <wd-select appearance="outline" context="main/frm34p/sfld24p"></wd-select>
                      </wd-cell>
                      <wd-cell [width]="6">
                        <wd-select appearance="outline" context="main/frm34p/sfld25p" (wdChange)="throwEventOf('/main/frm34p/oslte147p')"></wd-select>
                      </wd-cell>
                    </wd-row>
                    <wd-row>
                      <wd-cell [width]="4">
                        <wd-input appearance="outline" context="main/frm34p/fld107p"></wd-input>
                      </wd-cell>
                      <wd-cell [width]="4">
                        <wd-input appearance="outline" context="main/frm34p/fld108p"></wd-input>
                      </wd-cell>
                      <wd-cell [width]="4">
                        <wd-input context="main/frm34p/fld106p" appearance="outline"></wd-input>
                      </wd-cell>
                    </wd-row>
                  </wd-grid>
                </wr-content>
              </wd-card>
            </wd-cell>
          </wd-row>
          <wd-row>
            <wd-cell [width]="12">
              <wd-data-grid elevation="0" cols="main/mfrm2p/data/fld112p | main/mfrm2p/data/fld110p | main/mfrm2p/data/fld113p | main/mfrm2p/data/fld109p" [rows]="valueOf('main/mfrm2p/data')">
                <wr-content for="header[fld112p]">
                  {{ labelOf('.') | wrLocalize }}
                </wr-content>
                <wr-content for="data[fld112p]">
                  {{ valueOf('./value',row) | wrLocalize }}
                </wr-content>
                <wr-content for="header[fld110p]">
                  {{ labelOf('.') | wrLocalize }}
                </wr-content>
                <wr-content for="data[fld110p]">
                  <wd-file-input [showLabel]="false"></wd-file-input>
                </wr-content>
                <wr-content for="header[fld113p]">
                  {{ labelOf('.') | wrLocalize }}
                </wr-content>
                <wr-content for="data[fld113p]">
                  <wd-datepicker></wd-datepicker>
                </wr-content>
                <wr-content for="header[fld109p]">
                  {{ labelOf('.') | wrLocalize }}
                </wr-content>
                <wr-content for="data[fld109p]">
                  <wd-input type="text" [showLabel]="false"></wd-input>
                </wr-content>
              </wd-data-grid>
            </wd-cell>
          </wd-row>
        </wd-grid>
      </wr-content>
      <wr-content for="title[main]">
        {{ labelOf('.') | wrLocalize }}
      </wr-content>
      <wr-content for="action[oslte146p]">
        <wd-button color="success"></wd-button>
      </wr-content>
    </wd-card>
  </wr-content>
  <wr-content for="breadcrumb">
    <wd-button context="backEvent" iconText="arrow_back"></wd-button>
  </wr-content>
</wr-page>